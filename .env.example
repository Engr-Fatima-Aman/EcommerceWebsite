# ==========================================================================
# RIWAQ — Environment Variables
# Copy this file to ".env" (without the .example) and fill in your real values
# NEVER commit .env to git — it has secrets
# ==========================================================================

# -------- App Settings --------
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars

# -------- Brand Info (shown in emails, on site) --------
BRAND_NAME=RIWAQ Jewellery
BRAND_URL=http://localhost:3000
BRAND_PHONE=+92 300 1234567
BRAND_INSTAGRAM=https://instagram.com/riwaq
BRAND_SUPPORT_EMAIL=support@riwaq.pk

# -------- Email (Gmail SMTP via Nodemailer) --------
# 1. Use a Gmail account
# 2. Turn ON 2-Step Verification: https://myaccount.google.com/security
# 3. Create App Password: https://myaccount.google.com/apppasswords
#    (Select "Mail" + "Other" → name it "RIWAQ Website")
# 4. Paste the 16-character password below (no spaces)
EMAIL_USER=yourbrand@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM_NAME=RIWAQ Jewellery

# -------- PostEx COD Courier API --------
# Sign up at https://postex.pk/ as a merchant
# Get your API token from PostEx merchant dashboard
# Then call GET /services/integration/api/order/v2/get-merchant-address
# to find your pickup address code
POSTEX_API_TOKEN=
POSTEX_API_BASE_URL=https://api.postex.pk
POSTEX_PICKUP_ADDRESS_CODE=
POSTEX_MERCHANT_NAME=RIWAQ Jewellery

# -------- Manual Payment Methods --------
# Bank Transfer details — shown to customer at checkout
BANK_NAME=Meezan Bank
BANK_ACCOUNT_TITLE=RIWAQ Jewellery
BANK_ACCOUNT_NUMBER=01234567890123
BANK_IBAN=PK00MEZN0001234567890123

# JazzCash receiving account
JAZZCASH_NUMBER=03001234567
JAZZCASH_ACCOUNT_TITLE=RIWAQ Jewellery

# EasyPaisa receiving account
EASYPAISA_NUMBER=03001234567
EASYPAISA_ACCOUNT_TITLE=RIWAQ Jewellery

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %>RIWAQ Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body class="admin-body">

<div class="admin-shell">

    <!-- ===== Sidebar ===== -->
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <img src="/img/logo.svg" alt="RIWAQ" height="40">
            <div class="sidebar-subtitle">Admin Panel</div>
        </div>

        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <a href="/admin/products" class="<%= active === 'products' ? 'active' : '' %>">
                <i class="bi bi-gem"></i> Products
            </a>
            <a href="/admin/orders" class="<%= active === 'orders' ? 'active' : '' %>">
                <i class="bi bi-bag-check"></i> Orders
            </a>
            <a href="/admin/payments" class="<%= active === 'payments' ? 'active' : '' %>">
                <i class="bi bi-shield-check"></i> Verify Payments
            </a>
            <a href="/admin/customers" class="<%= active === 'customers' ? 'active' : '' %>">
                <i class="bi bi-people"></i> Customers
            </a>
            <a href="/admin/patterns" class="<%= active === 'patterns' ? 'active' : '' %>">
                <i class="bi bi-diagram-3"></i> Design Patterns
            </a>

            <div class="sidebar-divider"></div>
            <a href="/" target="_blank">
                <i class="bi bi-shop"></i> View Store
            </a>
            <a href="/logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </nav>
    </aside>

    <!-- ===== Main content ===== -->
    <div class="admin-main">
        <header class="admin-topbar">
            <h1 class="admin-page-title"><%= pageTitle %></h1>
            <div class="admin-user">
                <i class="bi bi-person-circle"></i>
                <span><%= user ? user.name : 'Admin' %></span>
            </div>
        </header>

        <div class="admin-content">
            <%- body %>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

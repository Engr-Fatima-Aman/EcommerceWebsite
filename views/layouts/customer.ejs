<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %>RIWAQ — Premium Jewellery</title>

    <!-- Google Fonts: Playfair Display (serif) + Poppins (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Custom RIWAQ stylesheet -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body>

<!-- ===== Top utility bar ===== -->
<div class="topbar d-none d-md-block">
    <div class="container d-flex justify-content-between align-items-center py-2">
        <div class="small">
            <i class="bi bi-telephone me-1"></i> <%= config.supportPhone %>
            <span class="mx-3 opacity-50">|</span>
            <i class="bi bi-envelope me-1"></i> <%= config.supportEmail %>
        </div>
        <div class="small">
            <% if (user) { %>
                <span class="me-3"><i class="bi bi-person-circle me-1"></i> <%= user.name %></span>
                <a href="/orders" class="text-decoration-none topbar-link me-3">My Orders</a>
                <a href="/logout" class="text-decoration-none topbar-link">Logout</a>
            <% } else { %>
                <a href="/login" class="text-decoration-none topbar-link me-3">Login</a>
                <a href="/register" class="text-decoration-none topbar-link">Register</a>
            <% } %>
        </div>
    </div>
</div>

<!-- ===== Brand + search + cart ===== -->
<header class="brand-bar">
    <div class="container py-4">
        <div class="row align-items-center g-3">
            <div class="col-lg-3 col-6">
                <a href="/" class="d-inline-block">
                    <img src="/img/logo.svg" alt="RIWAQ" height="50">
                </a>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <form action="/shop" method="GET" class="search-form d-flex">
                    <input type="text" name="search" class="form-control" placeholder="Search for rings, necklaces, earrings...">
                    <button type="submit" class="btn btn-gold"><i class="bi bi-search"></i></button>
                </form>
            </div>
            <div class="col-lg-3 col-6 text-end">
                <div class="d-flex justify-content-end gap-3 align-items-center">
                    <a href="/wishlist" class="header-icon">
                        <i class="bi bi-heart fs-4"></i>
                    </a>
                    <a href="/cart" class="header-icon position-relative">
                        <i class="bi bi-bag fs-4"></i>
                        <% if (cartCount > 0) { %>
                            <span class="cart-badge"><%= cartCount %></span>
                        <% } %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- ===== Main navigation ===== -->
<nav class="main-nav">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/shop">Shop All</a></li>
                <li><a href="/shop?type=Ring">Rings</a></li>
                <li><a href="/shop?type=Necklace">Necklaces</a></li>
                <li><a href="/shop?type=Earring">Earrings</a></li>
                <li><a href="/shop?type=Bracelet">Bracelets</a></li>
            </ul>
            <a href="/shop?occasion=Wedding" class="bridal-link d-none d-md-inline-block">
                <i class="bi bi-stars me-1"></i> Bridal Collection
            </a>
        </div>
    </div>
</nav>

<!-- ===== Page content ===== -->
<main class="page-main">
    <%- body %>
</main>

<!-- ===== Footer ===== -->
<footer class="site-footer">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-lg-4">
                <img src="/img/logo.svg" alt="RIWAQ" height="48" class="mb-3 footer-logo">
                <p class="small opacity-75">
                    RIWAQ crafts timeless jewellery for life's most precious moments —
                    where heritage craftsmanship meets contemporary elegance.
                </p>
                <div class="footer-social mt-3">
                    <a href="#"><i class="bi bi-instagram"></i></a>
                    <a href="#"><i class="bi bi-facebook"></i></a>
                    <a href="#"><i class="bi bi-whatsapp"></i></a>
                    <a href="#"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="col-lg-2 col-6">
                <h6 class="footer-title">Shop</h6>
                <ul class="footer-links">
                    <li><a href="/shop?type=Ring">Rings</a></li>
                    <li><a href="/shop?type=Necklace">Necklaces</a></li>
                    <li><a href="/shop?type=Earring">Earrings</a></li>
                    <li><a href="/shop?type=Bracelet">Bracelets</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-6">
                <h6 class="footer-title">Help</h6>
                <ul class="footer-links">
                    <li><a href="#">Shipping</a></li>
                    <li><a href="#">Returns</a></li>
                    <li><a href="#">Size Guide</a></li>
                    <li><a href="#">Care Guide</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="footer-title">Stay in Touch</h6>
                <p class="small opacity-75 mb-2">
                    Subscribe to receive new collection updates and private sale invitations.
                </p>
                <form class="d-flex">
                    <input type="email" class="form-control me-2" placeholder="Your email">
                    <button class="btn btn-gold">Subscribe</button>
                </form>
                <div class="mt-3 small opacity-75">
                    <i class="bi bi-geo-alt me-1"></i> <%= config.address %>
                </div>
            </div>
        </div>
    </div>
    <div class="footer-bottom text-center py-3">
        <small>© <%= new Date().getFullYear() %> RIWAQ — Crafted with care in Karachi, Pakistan</small>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

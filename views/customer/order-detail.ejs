<%# Customer Order Detail %>
<section class="breadcrumb-section">
    <div class="container">
        <nav class="breadcrumb-trail">
            <a href="/">Home</a> <span class="mx-2">/</span>
            <a href="/orders">My Orders</a> <span class="mx-2">/</span>
            <span>Order #<%= order.id %></span>
        </nav>
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h1 class="page-heading mb-0">Order #<%= order.id %></h1>
            <span class="status-badge status-<%= order.status.toLowerCase() %> fs-6"><%= order.status %></span>
        </div>
    </div>
</section>

<section class="section pt-3">
    <div class="container">

        <% if (typeof flash !== 'undefined' && flash) { %>
            <div class="alert-elegant alert-success mb-4">
                <i class="bi bi-check-circle me-1"></i> <%= flash %>
            </div>
        <% } %>

        <% if (order.tracking_number) { %>
            <div class="alert-elegant alert-success mb-4">
                <i class="bi bi-truck me-1"></i>
                <strong>PostEx Tracking:</strong> <span class="font-monospace"><%= order.tracking_number %></span>
                <a href="https://postex.pk/tracking" target="_blank" class="ms-2">Track →</a>
            </div>
        <% } %>

        <% if (order.payment_method && order.payment_method.toLowerCase() !== 'cash on delivery' && !['verified', 'submitted'].includes(order.payment_status)) { %>
            <div class="alert-elegant alert-warning mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <strong>Payment pending.</strong> Please complete payment and upload proof to start processing.
                </div>
                <a href="/orders/<%= order.id %>/payment" class="btn btn-gold btn-sm">Complete Payment</a>
            </div>
        <% } else if (order.payment_status === 'submitted') { %>
            <div class="alert-elegant alert-warning mb-4">
                <i class="bi bi-clock-history me-1"></i>
                Payment proof submitted — under review. We'll email you within 24 hours.
            </div>
        <% } else if (order.payment_status === 'verified') { %>
            <div class="alert-elegant alert-success mb-4">
                <i class="bi bi-shield-check me-1"></i>
                Payment verified.
            </div>
        <% } else if (order.payment_status === 'rejected') { %>
            <div class="alert-elegant alert-danger mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <i class="bi bi-x-circle me-1"></i>
                    <strong>Payment verification failed.</strong> Please re-upload a clearer proof.
                </div>
                <a href="/orders/<%= order.id %>/payment" class="btn btn-outline-gold btn-sm">Re-upload Proof</a>
            </div>
        <% } %>

        <div class="row g-4">
            <!-- ===== Items ===== -->
            <div class="col-lg-8">
                <div class="checkout-card">
                    <h5 class="checkout-section-title">Order Items</h5>
                    <% items.forEach(item => { %>
                        <div class="order-item-row">
                            <div>
                                <div class="fw-600"><%= item.name %></div>
                                <div class="text-muted small">Quantity: <%= item.quantity %> × Rs. <%= item.price.toLocaleString('en-PK') %></div>
                                <% if (item.customizations) { try { const c = JSON.parse(item.customizations); %>
                                    <% if (c.giftWrap) { %><span class="customization-badge small">Gift Wrap: <%= c.giftWrap %></span><% } %>
                                    <% if (c.engraving) { %><span class="customization-badge small">Engraving: "<%= c.engraving %>"</span><% } %>
                                    <% if (c.premiumBox) { %><span class="customization-badge small">Premium Box</span><% } %>
                                    <% if (c.express) { %><span class="customization-badge small">Express</span><% } %>
                                <% } catch(e) {} } %>
                            </div>
                            <div class="text-end fw-600">Rs. <%= (item.price * item.quantity).toLocaleString('en-PK') %></div>
                        </div>
                    <% }) %>
                </div>

                <div class="checkout-card mt-4">
                    <h5 class="checkout-section-title">Shipping Address</h5>
                    <div class="address-card">
                        <div><i class="bi bi-geo-alt me-2"></i> <%= order.address %></div>
                        <div class="text-muted ms-4"><%= order.city %></div>
                        <div class="text-muted ms-4"><i class="bi bi-telephone me-1"></i> <%= order.phone %></div>
                    </div>
                </div>
            </div>

            <!-- ===== Summary ===== -->
            <div class="col-lg-4">
                <div class="summary-box">
                    <h5 class="summary-title">Order Summary</h5>
                    <div class="summary-row"><span>Subtotal</span><span>Rs. <%= order.subtotal.toLocaleString('en-PK') %></span></div>
                    <% if (order.discount > 0) { %>
                        <div class="summary-row discount">
                            <span>Discount<% if (order.coupon) { %> (<%= order.coupon %>)<% } %></span>
                            <span>− Rs. <%= order.discount.toLocaleString('en-PK') %></span>
                        </div>
                    <% } %>
                    <div class="summary-row"><span>Shipping</span><span><%= order.shipping === 0 ? 'FREE' : 'Rs. ' + order.shipping.toLocaleString('en-PK') %></span></div>
                    <div class="summary-row"><span>Tax</span><span>Rs. <%= order.tax.toLocaleString('en-PK') %></span></div>
                    <hr>
                    <div class="summary-row total"><span>Total</span><span>Rs. <%= order.total.toLocaleString('en-PK') %></span></div>

                    <div class="mt-3 small">
                        <div class="d-flex justify-content-between text-muted">
                            <span>Payment</span><span><%= order.payment_method %></span>
                        </div>
                        <div class="d-flex justify-content-between text-muted">
                            <span>Placed on</span><span><%= new Date(order.created_at).toLocaleString('en-GB') %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

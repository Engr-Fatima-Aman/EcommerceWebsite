<%# Customer Home Page %>

<!-- ============ HERO ============ -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 hero-content">
                <p class="hero-eyebrow">— Heritage Craftsmanship Since 1985 —</p>
                <h1 class="hero-title">Where Every<br>Piece Tells a<br><em>Timeless</em> Story</h1>
                <p class="hero-sub mb-4">Discover RIWAQ's signature collection of handcrafted jewellery — meticulously designed for moments that matter most.</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/shop" class="btn btn-gold btn-lg">Shop Collection</a>
                    <a href="/shop?occasion=Wedding" class="btn btn-outline-gold btn-lg">Bridal Edit</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                <img src="/img/hero.svg" alt="RIWAQ Hero" class="img-fluid hero-image">
            </div>
        </div>
    </div>
</section>

<!-- ============ CATEGORIES STRIP ============ -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-eyebrow">Shop by Category</p>
            <h2 class="section-title">Curated Collections</h2>
            <div class="section-divider"></div>
        </div>
        <div class="row g-4 justify-content-center">
            <% categories.forEach(cat => { %>
                <div class="col-6 col-md-3">
                    <a href="/shop?type=<%= cat.name %>" class="text-decoration-none">
                        <div class="category-tile">
                            <div class="category-icon">
                                <% if (cat.name === 'Ring') { %><i class="bi bi-gem"></i>
                                <% } else if (cat.name === 'Necklace') { %><i class="bi bi-flower1"></i>
                                <% } else if (cat.name === 'Earring') { %><i class="bi bi-stars"></i>
                                <% } else { %><i class="bi bi-circle"></i><% } %>
                            </div>
                            <h5 class="mb-1"><%= cat.name %>s</h5>
                            <small class="text-muted"><%= cat.product_count %> pieces</small>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- ============ FEATURED PRODUCTS ============ -->
<section class="section section-cream">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-eyebrow">Handpicked for You</p>
            <h2 class="section-title">Featured Pieces</h2>
            <div class="section-divider"></div>
        </div>
        <div class="row g-4">
            <% featuredProducts.forEach(p => { %>
                <div class="col-6 col-md-4 col-lg-3">
                    <%- include('../partials/product-card', { p }) %>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- ============ BRIDAL BANNER ============ -->
<section class="bridal-banner">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <p class="hero-eyebrow text-light">— The Bridal Edit —</p>
                <h2 class="bridal-title">Your Forever Begins Here</h2>
                <p class="text-light opacity-75 mb-4">Exquisite bridal sets, statement chokers, and heirloom-worthy pieces designed for the most precious chapter of your story.</p>
                <a href="/shop?occasion=Wedding" class="btn btn-outline-light btn-lg">Explore Bridal</a>
            </div>
        </div>
    </div>
</section>

<!-- ============ LATEST ARRIVALS ============ -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-eyebrow">New This Week</p>
            <h2 class="section-title">Latest Arrivals</h2>
            <div class="section-divider"></div>
        </div>
        <div class="row g-4">
            <% latestProducts.forEach(p => { %>
                <div class="col-6 col-md-4 col-lg-3">
                    <%- include('../partials/product-card', { p }) %>
                </div>
            <% }) %>
        </div>
        <div class="text-center mt-5">
            <a href="/shop" class="btn btn-outline-gold btn-lg">View All Products</a>
        </div>
    </div>
</section>

<!-- ============ TRUST STRIP ============ -->
<section class="trust-strip">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <i class="bi bi-truck trust-icon"></i>
                <h6>Free Shipping</h6>
                <small class="text-muted">On orders above Rs. 25,000</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-shield-check trust-icon"></i>
                <h6>Lifetime Warranty</h6>
                <small class="text-muted">Authenticity guaranteed</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-arrow-repeat trust-icon"></i>
                <h6>Easy Returns</h6>
                <small class="text-muted">7-day return policy</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-headset trust-icon"></i>
                <h6>24/7 Support</h6>
                <small class="text-muted">WhatsApp & Phone</small>
            </div>
        </div>
    </div>
</section>

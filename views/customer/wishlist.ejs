<%# Wishlist Page %>
<section class="breadcrumb-section">
    <div class="container">
        <nav class="breadcrumb-trail">
            <a href="/">Home</a> <span class="mx-2">/</span> <span>Wishlist</span>
        </nav>
        <h1 class="page-heading">My Wishlist</h1>
    </div>
</section>

<section class="section pt-3">
    <div class="container">
        <% if (items.length === 0) { %>
            <div class="empty-state">
                <i class="bi bi-heart empty-icon"></i>
                <h4>Your wishlist is empty</h4>
                <p class="text-muted">Save the pieces you love to keep track of them.</p>
                <a href="/shop" class="btn btn-gold">Explore Collection</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% items.forEach(p => { %>
                    <div class="col-6 col-md-4 col-lg-3">
                        <%- include('../partials/product-card', { p }) %>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</section>

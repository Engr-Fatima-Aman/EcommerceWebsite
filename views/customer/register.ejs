<%# Customer Register %>
<section class="auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="auth-card">
                    <div class="text-center mb-4">
                        <img src="/img/logo.svg" alt="RIWAQ" height="50" class="mb-3">
                        <h2 class="auth-title">Join RIWAQ</h2>
                        <p class="text-muted">Create your account in seconds</p>
                        <div class="divider-ornament"></div>
                    </div>

                    <% if (error) { %>
                        <div class="alert-elegant alert-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i> <%= error %>
                        </div>
                    <% } %>

                    <form action="/register" method="POST" class="form-elegant">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="name" class="form-control" placeholder="Your full name" required>
                            </div>
                            <div class="col-md-7">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" placeholder="you@email.com" required>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">Phone</label>
                                <input type="tel" name="phone" class="form-control" placeholder="03XX XXXXXXX">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" placeholder="At least 6 characters" minlength="6" required>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-gold w-100 btn-lg mt-4">Create Account</button>
                    </form>

                    <p class="text-center mt-4 mb-0 small">
                        Already have an account? <a href="/login" class="link-gold">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

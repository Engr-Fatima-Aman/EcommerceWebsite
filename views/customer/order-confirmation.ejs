<%# Order Confirmation Page %>
<section class="section">
    <div class="container">
        <div class="confirmation-card mx-auto">
            <div class="confirmation-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <h1 class="confirmation-title">Order Placed Successfully!</h1>
            <p class="text-muted">Thank you for shopping with RIWAQ. Your order has been received and is being processed.</p>

            <div class="confirmation-detail-card mt-4">
                <div class="row text-center g-3">
                    <div class="col-md-4">
                        <div class="conf-label">Order Number</div>
                        <div class="conf-value">#<%= orderId %></div>
                    </div>
                    <div class="col-md-4">
                        <div class="conf-label">Total Amount</div>
                        <div class="conf-value">Rs. <%= total.toLocaleString('en-PK') %></div>
                    </div>
                    <div class="col-md-4">
                        <div class="conf-label">Payment Method</div>
                        <div class="conf-value"><%= paymentResult.method %></div>
                    </div>
                </div>

                <div class="payment-message mt-4">
                    <i class="bi bi-info-circle me-2"></i>
                    <%= paymentResult.message %>
                </div>

                <% if (typeof trackingNumber !== 'undefined' && trackingNumber) { %>
                    <div class="tracking-block mt-3">
                        <div class="tracking-label"><i class="bi bi-truck me-1"></i> PostEx Tracking Number</div>
                        <div class="tracking-number"><%= trackingNumber %></div>
                        <a href="https://postex.pk/tracking" target="_blank" class="small">Track your parcel on postex.pk →</a>
                    </div>
                <% } %>

                <% if (paymentResult.accountDetails) { %>
                    <div class="bank-details">
                        <h6>Bank Account Details:</h6>
                        <div><strong>Bank:</strong> <%= paymentResult.accountDetails.bank %></div>
                        <div><strong>Account #:</strong> <%= paymentResult.accountDetails.account %></div>
                        <% if (paymentResult.accountDetails.iban) { %><div><strong>IBAN:</strong> <%= paymentResult.accountDetails.iban %></div><% } %>
                    </div>
                <% } %>
            </div>

            <!-- ===== What's next (customer-friendly summary) ===== -->
            <div class="next-steps mt-4">
                <p class="text-muted">
                    <i class="bi bi-envelope-check me-1 text-gold"></i>
                    A confirmation has been emailed to you with full order details.
                    <% if (typeof trackingNumber !== 'undefined' && trackingNumber) { %>
                        We'll share dispatch updates as your parcel moves.
                    <% } else { %>
                        We'll begin preparing your order once payment is verified.
                    <% } %>
                </p>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-4 flex-wrap">
                <a href="/orders/<%= orderId %>" class="btn btn-gold">View Order Details</a>
                <a href="/shop" class="btn btn-outline-gold">Continue Shopping</a>
            </div>
        </div>
    </div>
</section>

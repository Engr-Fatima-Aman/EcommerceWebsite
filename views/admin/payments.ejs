<%# Admin: Pending Payments Verification %>

<div class="admin-card">
    <p class="text-muted small mb-3">
        Orders awaiting payment verification (Bank Transfer, JazzCash, EasyPaisa).
        Approve to release the order for dispatch — PostEx courier will be auto-booked.
    </p>

    <% if (orders.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size:3rem;"></i>
            <p class="text-muted mt-3 mb-0">All payments are up to date! 🎉</p>
        </div>
    <% } else { %>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Method</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Proof</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(o => { %>
                        <tr>
                            <td class="fw-600">#<%= o.id %></td>
                            <td>
                                <div><%= o.customer_name %></div>
                                <div class="text-muted small"><%= o.customer_email %></div>
                            </td>
                            <td><span class="small"><%= o.payment_method %></span></td>
                            <td>Rs. <%= o.total.toLocaleString('en-PK') %></td>
                            <td>
                                <% if (o.payment_status === 'submitted') { %>
                                    <span class="badge bg-warning text-dark">Submitted</span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><%= o.payment_status %></span>
                                <% } %>
                            </td>
                            <td>
                                <% if (o.payment_proof) { %>
                                    <a href="<%= o.payment_proof %>" target="_blank" class="small">View →</a>
                                <% } else { %>
                                    <span class="text-muted small">Not uploaded</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/admin/orders/<%= o.id %>" class="btn btn-sm btn-admin-outline">Review</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | RIWAQ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body class="admin-login-page">

    <div class="admin-login-card">
        <div class="text-center mb-4">
            <img src="/img/logo.svg" alt="RIWAQ" height="55" class="mb-3">
            <h3 class="admin-login-title">Admin Panel</h3>
            <p class="text-muted small mb-0">Sign in to manage RIWAQ</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger small">
                <i class="bi bi-exclamation-triangle me-1"></i> <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            <div class="mb-3">
                <label class="form-label small">Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><i class="bi bi-person"></i></span>
                    <input type="email" name="email" class="form-control" required>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label small">Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" class="form-control" required>
                </div>
            </div>
            <button type="submit" class="btn btn-admin-gold w-100 btn-lg">
                <i class="bi bi-shield-lock me-1"></i> Sign In
            </button>
        </form>

        <div class="demo-credentials mt-4">
            <small class="text-muted d-block text-center mb-1">— Default Admin Credentials —</small>
            <small class="d-block text-center">📧 admin@riwaq.pk</small>
            <small class="d-block text-center">🔑 admin123</small>
        </div>

        <div class="text-center mt-4">
            <a href="/" class="small text-muted text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Back to Store
            </a>
        </div>
    </div>

</body>
</html>
